{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "types": ["audioworklet"]
  },
  "include": ["src/features/synth-engine/worklets/**/*.ts"],
  "exclude": ["**/*.d.ts"]
}
