{
  "name": "opencollidoscope-web",
  "private": true,
  "version": "0.0.0",
  "license": "GPL-3.0-or-later",
  "homepage": "https://okathira-dev.github.io/opencollidoscope-web/",
  "repository": {
    "type": "git",
    "url": "https://github.com/okathira-dev/opencollidoscope-web.git"
  },
  "type": "module",
  "engines": {
    "node": "^24.14.0"
  },
  "scripts": {
    "dev": "vite --host",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "compile": "tsc --noEmit && tsc --noEmit -p tsconfig.worklet.json",
    "prepare": "husky",
    "format": "biome format",
    "format:fix": "biome format --write",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "lint-md": "markdownlint-cli2 **/*.{md,mdx,mdc}",
    "lint-md:fix": "markdownlint-cli2 **/*.{md,mdx,mdc} --fix",
    "biome-check": "biome check",
    "biome-check:fix": "biome check --write",
    "check": "pnpm biome-check && pnpm compile && pnpm lint-md",
    "check:fix": "pnpm biome-check:fix && pnpm lint-md:fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "coi-serviceworker": "^0.1.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/audioworklet": "^0.0.100",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "markdownlint-cli2": "^0.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620"
}
